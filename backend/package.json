{
  "name": "@dokimi/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "db:migrate:local": "wrangler d1 migrations apply dokimi --local",
    "db:migrate:remote": "wrangler d1 migrations apply dokimi --remote",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "hono": "^4.8.5",
    "zod": "^3.25.76"
  },
  "overrides": {
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "miniflare": "^4.20250712.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.25.0"
  }
}
